# Supabase (client — Vite exposes VITE_* to the browser)
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
# Project URL → VITE_SUPABASE_URL
# anon public key → VITE_SUPABASE_ANON_KEY
# Run supabase/criminal_reports.sql in SQL Editor before saving reports.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# fal.ai API key (server-side only — never committed)
# Create a key at https://fal.ai/dashboard/keys
# Format: key_id:key_secret (no quotes around the value)
FAL_KEY=
